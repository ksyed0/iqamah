# .env.example — Environment Variables Template

# ========================================
# Iqamah macOS App — Environment Variables
# ========================================
#
# This is a TEMPLATE file. Copy this to `.env` and fill in actual values.
# The `.env` file is gitignored and must NEVER be committed.
#
# To use:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in `.env`
# 3. Never commit `.env` to version control
#

# ========================================
# Application Configuration
# ========================================

# Application environment (development | staging | production)
APP_ENVIRONMENT=development

# Logging level (DEBUG | INFO | WARN | ERROR | CRITICAL)
LOG_LEVEL=DEBUG

# ========================================
# External API Keys (if needed in future)
# ========================================

# Example: Prayer times API (if using external service)
# PRAYER_TIMES_API_KEY=your_api_key_here

# Example: Weather API (if integrating weather data)
# WEATHER_API_KEY=your_api_key_here

# Example: Analytics service (if using external analytics)
# ANALYTICS_API_KEY=your_api_key_here

# ========================================
# Feature Flags
# ========================================

# Enable notifications (true | false)
ENABLE_NOTIFICATIONS=false

# Enable crash reporting (true | false)
ENABLE_CRASH_REPORTING=false

# ========================================
# Database Configuration (if needed)
# ========================================

# Example: Remote database URL
# DATABASE_URL=your_database_url_here

# ========================================
# Notes
# ========================================
#
# - Keep this file updated whenever new environment variables are added
# - Document the purpose of each variable clearly
# - Use descriptive variable names
# - Group related variables together
# - Never store actual secrets in this file — only placeholders
#
